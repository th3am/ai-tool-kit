APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

AI_PROVIDER=chatgpt
GEMINI_API_KEY=
CHATGPT_API_ENDPOINT=https://gpt-api.metaphilia.com/chat
CHATGPT_API_KEY=
CHATGPT_API_MODE=auto
CHATGPT_MODEL=gpt-4.1-mini
CHATGPT_MAX_OUTPUT_TOKENS=16000
CHATGPT_TIMEOUT=120
CHATGPT_CONNECT_TIMEOUT=15
CHATGPT_RETRY_ATTEMPTS=3
CHATGPT_RETRY_DELAY_MS=1500
CHATGPT_SCENE_BATCH_SIZE=2
AI_ANIMATION_TIMEOUT=120
AI_ANIMATION_RETRY_ATTEMPTS=3
AI_ANIMATION_RETRY_DELAY_MS=1500

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
QUEUE_RETRY_AFTER=2100
QUEUE_STALE_AFTER_MINUTES=40
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Video explainer command paths. Ubuntu commonly uses /usr/bin for FFmpeg.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
EDGE_TTS_PATH=edge-tts
WKHTMLTOIMAGE_PATH=wkhtmltoimage
NODE_BINARY=
NPM_BINARY=
CHROME_PATH=
EDGE_TTS_API_URL=https://tts-api.eduvoo.com/generate
EDGE_TTS_API_TIMEOUT=120
EDGE_TTS_RATE="+0%"
EDGE_TTS_PITCH="+0Hz"
VIDEO_SUBTITLE_FONT="DejaVu Sans"

METAPHILIA_API_KEY=
METAPHILIA_SENDER=
METAPHILIA_WEBHOOK_SECRET=
METAPHILIA_SEND_MESSAGE_URL=https://metaphilia.com/send-message
METAPHILIA_SEND_MEDIA_URL=https://metaphilia.com/send-media
METAPHILIA_SEND_BUTTON_URL=https://metaphilia.com/send-button
METAPHILIA_TIMEOUT=30
